<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>edit Product</title>
</head>
<body>
    <h1>Edit Product</h1>
    <form action="/product<%=e._id%>?_method=PUT" method="post">
        <label for="">Name</label>
        <input type="text" name="Ename" id="" value="<%=e.name%>" required>
        <label for="">img</label>
        <input type="text" name="Eimg" id="" value="<%=e.img%>" required>
        <label for="">Price</label>
        <input type="number" name="Eprice" id="" min="0" value="<%=e.price%>"  required>
        <label for="">qty</label>
        <input type="number" name="Eqty" value="<%=e.qty%>" required>
        <label for="">rating</label>
        <input type="number" name="Erating" id="" min="1" max="5" value="<%=e.rating%>" required>
        <label for="">desc</label>
        <input type="text" name="Edesc" id="" value="<%=e.desc%>" required>
        <button type="submit">Edit</button>
    </form>
</body>
</html>